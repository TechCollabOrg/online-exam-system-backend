<component name="ProjectRunConfigurationManager">
  <configuration default="false" name="ExamApplication" type="SpringBootApplicationConfigurationType" factoryName="Spring Boot">
    <option name="ACTIVE_PROFILES" value="dev" />
    <module name="exam" />
    <option name="SPRING_BOOT_MAIN_CLASS" value="cn.org.alan.exam.ExamApplication" />
    <extension name="net.ashald.envfile">
      <option name="IS_ENABLED" value="true" />
      <option name="LEVEL" value="PROJECT" />
      <option name="IGNORE_MISSING_FILES" value="true" />
      <ENTRIES>
        <ENTRY IS_ENABLED="true" PARSER="runconfig" PATH="$PROJECT_DIR$/env.local" />
      </ENTRIES>
    </extension>
    <method v="2">
      <option name="Make" enabled="true" />
    </method>
  </configuration>
</component>
