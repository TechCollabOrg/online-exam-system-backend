# 复制本文件为 env.local 后填写（env.local 已 gitignore，勿提交 Git）
MYSQL_PASSWORD=你的MySQL密码
REDIS_PASSWORD=你的Redis密码

# ========== 硅基流动 SiliconFlow（AI 阅卷 + AI 助手）==========
# 1. 打开 https://cloud.siliconflow.cn/account/ak 创建 API Key
# 2. 把 Key 填到下面 LLM_API_KEY= 后面（形如 sk-xxxxxxxx）
# 3. 保存后重启后端（.\start-all.ps1）
CHAT_PLATFORM_TYPE=llm
LLM_API_KEY=在此粘贴你的硅基流动API密钥
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3

# 可选：换模型时在 https://cloud.siliconflow.cn/models 查看名称，例如：
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_MODEL=Pro/deepseek-ai/DeepSeek-V3

# 可选：AI 阅卷前联网检索（与硅基流动无关，需 Serper）
# AI_GRADING_WEB_SEARCH=true
# SERPER_API_KEY=
