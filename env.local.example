# 本地开发环境变量（复制为 env.local 后修改，勿提交 env.local）
# 供 IDEA / Cursor 启动配置、start-dev.ps1 读取
# application-dev.yml 通过 ${MYSQL_PASSWORD}、${REDIS_PASSWORD} 占位符引用

MYSQL_PASSWORD=你的MySQL密码
REDIS_PASSWORD=你的Redis密码

# 可选：覆盖其它默认值
# MYSQL_USERNAME=root
# MYSQL_URL=jdbc:mysql://127.0.0.1:3306/db_exam?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8&allowPublicKeyRetrieval=true&useSSL=false
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
